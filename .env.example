DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crawler

# Fetching
REQUEST_TIMEOUT=20.0
JS_RENDER_TIMEOUT=30.0
USER_AGENT=CrawlerBot/0.1 (+https://github.com/proark1/crawler)
MAX_RESPONSE_BYTES=10000000
MAX_REDIRECTS=5
FETCH_RETRIES=2

# Crawl budget / concurrency
MAX_PAGES_HARD_LIMIT=100
MAX_DEPTH_HARD_LIMIT=5
CRAWL_CONCURRENCY=8
JS_CONCURRENCY=2
PER_HOST_DELAY=0.5

# Politeness / safety
RESPECT_ROBOTS=true
# SSRF guard: block requests to private/loopback/link-local addresses. Disable only in trusted envs.
BLOCK_PRIVATE_ADDRESSES=true

# Security
# Required in production. Empty = auth disabled.
API_KEY=
# Comma-separated; e.g. https://crawler-ui.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*

# Observability
LOG_LEVEL=INFO
