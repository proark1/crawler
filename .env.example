ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crawler
REQUEST_TIMEOUT=20.0
JS_RENDER_TIMEOUT=30.0
USER_AGENT=CrawlerBot/0.1

# Networking guards.
MAX_RESPONSE_BYTES=10485760
MAX_RETRIES=2
CRAWL_CONCURRENCY=4
MAX_REDIRECTS=5

# SSRF protection (block private / loopback / link-local / metadata addresses).
BLOCK_PRIVATE_ADDRESSES=true
# Comma-separated hostnames exempt from the SSRF block (e.g. for local testing).
SSRF_ALLOWLIST=

# JS rendering performance.
BLOCK_RESOURCES_IN_JS=true
JS_CONTEXT_POOL_SIZE=2

# HTTP client pool / performance.
HTTP2=true
MAX_KEEPALIVE_CONNECTIONS=20
MAX_CONNECTIONS=100
DNS_CACHE_TTL=300.0

# Anti-bot / tiered fetch strategy.
ANTIBOT_ENABLED=true
ESCALATE_ON_BLOCK=true
# curl_cffi impersonation target (needs the `impersonate` extra). "" disables.
IMPERSONATE_BROWSER=chrome
ACCEPT_LANGUAGE=en-US,en;q=0.9
# Stealth headless browser (uses patchright when the `stealth` extra is installed).
BROWSER_STEALTH=true
PERSIST_COOKIES=true
DOMAIN_PROFILE_SIZE=5000
# Proxies (single + rotation pool). Proxied targets are still SSRF-validated.
PROXY_URL=
PROXY_POOL=
# Tiers >= this route through a proxy: 0=static 1=impersonate 2=browser.
PROXY_FROM_TIER=1
# Optional FlareSolverr endpoint for Cloudflare/DDoS-Guard challenge solving.
FLARESOLVERR_URL=

# Caching / extraction.
RECRAWL_MAX_AGE=0.0
STORE_HTML=true
EXTRACT_METADATA=true
EMIT_MARKDOWN=true

# Politeness.
RESPECT_ROBOTS=true
RESPECT_CRAWL_DELAY=true
PER_HOST_DELAY=0.0

# Rate limiting (per client IP / API key). 0 = disabled.
RATE_LIMIT_PER_MINUTE=0

# Observability.
ENABLE_METRICS=true
LOG_LEVEL=INFO
LOG_JSON=true
SENTRY_DSN=

# Required in production (service refuses to start without it). Empty = auth disabled.
API_KEY=
# Comma-separated; e.g. https://crawler-ui.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*
